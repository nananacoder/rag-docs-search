# Copy to .env for local dev. Pydantic-settings reads from .env automatically.

APP_ENV=dev
LOG_LEVEL=INFO

# Which retrieval implementation to use. "mock" for local no-GCP dev.
# In Phase 1 switch to "discovery_engine"; Phase 2 adds "pgvector".
RETRIEVAL_BACKEND=mock

# GCP project + location — only required when backend != "mock"
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# Vertex AI Search (Phase 1)
DISCOVERY_ENGINE_DATASTORE_ID=
DISCOVERY_ENGINE_ENGINE_ID=
DISCOVERY_ENGINE_COLLECTION=default_collection

# Generation
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-pro
GENERATION_TEMPERATURE=0.2

# Retrieval shape
DEFAULT_TOP_K=5
MAX_TOP_K=20

# CORS origins (comma-separated). Angular dev server in local dev.
CORS_ORIGINS=http://localhost:4200
